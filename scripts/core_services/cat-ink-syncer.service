[Unit]
Description=LeopardCat AgentOS Session Syncer (Operation Cat-Ink)
After=network.target

[Service]
EnvironmentFile=-%h/agentos/.env
ExecStart=/usr/bin/python3 %h/agentos/scripts/core_services/session_syncer.py
Restart=always
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
