# 🌐 AgentManager Environment Template
# Copy this to .env and fill in the values.

# 📂 Data Layer Configuration
# Path to your private agent-data repository (where memory and status are stored)
AGENT_DATA_ROOT=/home/ubuntu/agent-data

# 🔑 Secrets & Tokens
# Your GitHub Personal Access Token (with repo scope)
GITHUB_TOKEN=your_github_token_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Authorized Telegram Channel/User ID
TELEGRAM_CHANNEL_ID=your_telegram_id_here

# 🧠 AI Configuration
# Gemini API Key (if using the bot bridge)
GEMINI_API_KEY=your_gemini_api_key_here

# 📡 Command Center
# The GitHub repository for your AI Command Center
COMMAND_CENTER_REPO=alstonhuang/AI_Command_Center

# 🧠 Advanced (Optional)
# Path to the Antigravity Knowledge Base
KNOWLEDGE_ROOT=/home/ubuntu/.gemini/antigravity/knowledge
AGENT_DATA_DIR=/home/ubuntu/agent-data
