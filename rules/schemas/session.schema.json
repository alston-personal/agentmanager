{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentmanager/session.schema.json",
  "title": "AgentManager Session",
  "description": "A single agent work session lifecycle record",
  "type": "object",
  "required": ["session_id", "project_id", "agent_id", "started_at", "status"],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "UUID v4 for this session"
    },
    "project_id": {
      "type": "string",
      "description": "Project slug this session belongs to"
    },
    "agent_id": {
      "type": "string",
      "description": "Identifier for the agent (e.g. 'Antigravity-IDE', 'TelegramAgent')"
    },
    "agent_role": {
      "type": "string",
      "enum": ["engineer", "analyst", "creative", "qa", "orchestrator"],
      "description": "Role this agent played in the session"
    },
    "entry_mode": {
      "type": "string",
      "enum": ["work-on", "telegram", "manual", "handover", "bootstrap"],
      "description": "How this session was initiated"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["active", "closed", "abandoned", "handed_over"],
      "description": "Current lifecycle state of this session"
    },
    "objective": {
      "type": "string",
      "description": "What this session was trying to accomplish"
    },
    "summary": {
      "type": "string",
      "description": "What was actually accomplished"
    },
    "tasks_started": {
      "type": "array",
      "items": { "type": "string" },
      "description": "task_ids that were started in this session"
    },
    "tasks_completed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "task_ids completed in this session"
    },
    "tasks_blocked": {
      "type": "array",
      "items": { "type": "string" },
      "description": "task_ids that became blocked during this session"
    },
    "files_touched": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Relative file paths modified during this session"
    },
    "handover": {
      "type": "object",
      "properties": {
        "pending_tasks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "task_ids or plain descriptions of unfinished work"
        },
        "next_agent_brief": {
          "type": "string",
          "description": "Plain-language instructions for the next agent picking up this project"
        },
        "context_notes": {
          "type": "string",
          "description": "Key context that the next agent must know before starting"
        }
      }
    }
  }
}
