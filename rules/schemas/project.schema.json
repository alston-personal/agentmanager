{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agentmanager/project.schema.json",
  "title": "AgentManager Project",
  "description": "Structured project metadata for Agent OS control plane",
  "type": "object",
  "required": ["project_id", "display_name", "phase", "status", "created_at", "updated_at"],
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Slug identifier, e.g. leopardcat-tarot",
      "pattern": "^[a-z0-9-]+$"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "phase": {
      "type": "string",
      "enum": ["idea", "planning", "active", "review", "maintenance", "paused", "archived"],
      "description": "Current development phase"
    },
    "status": {
      "type": "string",
      "description": "Short status label, e.g. '🚀 In Progress', '✅ Stable'"
    },
    "summary": {
      "type": "string",
      "description": "One-paragraph description of the project"
    },
    "current_focus": {
      "type": "string",
      "description": "What is actively being worked on right now"
    },
    "next_action": {
      "type": "string",
      "description": "The very next thing an agent should do when entering this project"
    },
    "actual_code_path": {
      "type": "string",
      "description": "Absolute filesystem path to the code (logic layer)",
      "examples": ["/home/ubuntu/agentmanager/workspace/leopardcat-tarot"]
    },
    "data_path": {
      "type": "string",
      "description": "Absolute path in agent-data (data layer)",
      "examples": ["/home/ubuntu/agent-data/projects/leopardcat-tarot"]
    },
    "sector": {
      "type": "string",
      "enum": ["Infrastructure", "Product", "Creative", "Research", "Unknown"],
      "description": "Strategic sector classification"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "description": "Priority weight: 10=highest, 0=idle"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form tags for filtering"
    },
    "assigned_agents": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Agent IDs currently assigned to this project"
    },
    "repo_url": {
      "type": "string",
      "format": "uri",
      "description": "GitHub or other VCS URL"
    },
    "health": {
      "type": "object",
      "properties": {
        "freshness": {
          "type": "string",
          "enum": ["fresh", "stale", "unknown"],
          "description": "Whether STATUS.md is in sync with code changes"
        },
        "sync_state": {
          "type": "string",
          "enum": ["synced", "pending_report", "diverged"],
          "description": "Whether agent-data reflects reality"
        },
        "last_verified_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
