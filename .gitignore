!projects/README.md
projects_status/
data/
bin/
ollama*

# OS & Temp
.DS_Store
Thumbs.db
temp_cc/
*.tmp
*.log
.secrets/

# Backups and Local State
.agent/backups/
memory.local-backup-*/
*.backup
*.old
*.swp
.env.backup_*
*.code-workspace
