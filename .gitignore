# AI Command Center Git Ignore

# Ignore actual development code
workspace/
dev/

# System files
.env
.gh_token
*.token

# Python
__pycache__/
*.pyc

# Data-layer mounts and local state
memory
STATUS.md
projects/*
!projects/.gitignore
!projects/README.md

# OS & Temp
.DS_Store
Thumbs.db
temp_cc/
*.tmp
*.log
.secrets/

# Backups and Local State
.agent/backups/
memory.local-backup-*/
*.backup
*.old
*.swp
.env.backup_*
